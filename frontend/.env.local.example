# ACRA MES — frontend environment template.
# Copy to frontend/.env.local and adjust if your backend runs elsewhere. Never commit .env.local.
#
#   cp frontend/.env.local.example frontend/.env.local

# Backend URL the browser calls directly (must be reachable from the client).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend URL the Next.js server-side auth proxy (app/api/auth/*) calls.
# Usually the same as NEXT_PUBLIC_API_URL for local dev.
BACKEND_URL=http://localhost:8000
