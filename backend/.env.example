# ACRA MES — backend environment template.
# Copy to backend/.env and fill in real values. Never commit the populated .env.
#
#   cp backend/.env.example backend/.env

# --- Database -------------------------------------------------------------
# Async SQLAlchemy DSN. Use port 5433 with the Docker Compose Postgres in this repo;
# use 5432 for a locally installed PostgreSQL.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/acra_db

# Browser origins allowed to call this API, comma-separated. Defaults to the frontend's
# documented dev port; override to run the frontend on another port (a second worktree, or an
# e2e run against a free port) — a mismatch here shows up as every XHR being CORS-blocked.
CORS_ORIGINS=http://localhost:3000

# --- Auth / JWT -----------------------------------------------------------
# Generate a unique random secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- AI receiving-document extraction (OCR) -------------------------------
# Only needed for the receiving/OCR flow. Leave as placeholders to run the rest of the app.
# Primary extractor: Google Gemini; fallback: Anthropic Claude.
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
